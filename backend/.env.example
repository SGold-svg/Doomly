# Doomly Production Environment
# Copy this file to .env and fill in your values

# ===================
# Flask Configuration
# ===================
FLASK_ENV=production
SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-this

# ===================
# Database
# ===================
# For PostgreSQL (recommended for production)
DATABASE_URL=postgresql://username:password@host:5432/doomly

# For SQLite (development only - not recommended for production)
# DATABASE_URL=sqlite:///doomly_prod.db

# ===================
# Email (SMTP)
# ===================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Or use Mailgun:
# MAIL_SERVER=smtp.mailgun.org
# MAIL_PORT=587
# MAIL_USERNAME=postmaster@your-domain.mailgun.org
# MAIL_PASSWORD=your-mailgun-password

# ===================
# Server
# ===================
PORT=5000
HOST=0.0.0.0

# ===================
# CORS (Cross-Origin)
# ===================
# Add your frontend domain in production
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# ===================
# File Uploads
# ===================
UPLOAD_FOLDER=/app/uploads
MAX_CONTENT_LENGTH=16777216

# ===================
# Security
# ===================
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# ===================
# Rate Limiting
# ===================
RATELIMIT_ENABLED=true
RATELIMIT_DEFAULT=200 per day, 50 per hour
