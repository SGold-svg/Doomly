# Doomly Production Environment Variables
# Copy this file to .env and customize

# Database
DB_USER=doomly
DB_PASSWORD=change-this-to-a-secure-password
DB_NAME=doomly

# Security (Generate secure keys!)
SECRET_KEY=change-this-to-a-very-long-random-secret-key-at-least-32-characters
JWT_SECRET_KEY=change-this-to-another-very-long-random-secret-key-at-least-32-characters

# Email (SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
